# ─── Foodzie Server Environment — EXAMPLE (safe to commit) ───────────────────

# Express
PORT=5000

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# JWT — generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_strong_random_secret_here
JWT_EXPIRES_IN=7d

# Razorpay — get keys from https://dashboard.razorpay.com
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Supabase PostgreSQL — connection pooling (used at runtime)
DATABASE_URL="postgresql://USER:PASSWORD@host:6543/postgres?pgbouncer=true"

# Supabase PostgreSQL — direct connection (used for migrations only)
DIRECT_URL="postgresql://USER:PASSWORD@host:5432/postgres"
